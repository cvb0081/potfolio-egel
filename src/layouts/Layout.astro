---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Egel Xhaferaj — Freelance Backend Developer | C# & ASP.NET Core",
  description = "Freelance software engineer with 5+ years building scalable backend systems and SaaS products. Specializing in C#, ASP.NET Core, and clean architecture. Available for hire."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Egel Xhaferaj" />

    <!-- Canonical -->
    <link rel="canonical" href="https://egelxh.dev" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://egelxh.dev" />
    <meta property="og:image" content="https://egelxh.dev/og-image.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://egelxh.dev/og-image.png" />

    <!-- Theme & Geo -->
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="geo.region" content="US" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <!-- Font preload -->
    <link rel="preload" href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700,900&f[]=cabinet-grotesk@700,800,900&display=swap" as="style" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700,900&f[]=cabinet-grotesk@700,800,900&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "mainEntity": {
        "@type": "Person",
        "name": "Egel Xhaferaj",
        "jobTitle": "Freelance Software Engineer",
        "url": "https://egelxh.dev",
        "image": "https://egelxh.dev/headshot.jpg",
        "email": "xhaferajegel@gmail.com",
        "description": "Freelance software engineer with 5+ years building scalable backend systems and SaaS products.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Tirana",
          "addressCountry": "AL"
        },
        "alumniOf": {
          "@type": "EducationalOrganization",
          "name": "BSc in Software Engineering"
        },
        "knowsAbout": [
          "C#", "ASP.NET Core", "Clean Architecture", "PostgreSQL",
          "Domain-Driven Design", "CQRS", "Docker", "SaaS Development",
          "REST APIs", "Microservices"
        ],
        "knowsLanguage": ["Albanian", "English", "Italian"],
        "sameAs": [
          "https://linkedin.com/in/egel",
          "https://github.com/cvb0081",
          "https://www.upwork.com/freelancers/~012899d2f987341308"
        ]
      }
    })} />

    <title>{title}</title>
  </head>
  <body class="bg-bg text-text-primary">
    <slot />
    <script>
      // Scroll-triggered reveal animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
