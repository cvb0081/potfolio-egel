---
const roleTags = [
  { label: 'Software Engineer', primary: true },
  { label: 'Technical Lead', primary: false },
  { label: 'Backend Architect', primary: false },
  { label: 'Product Engineer', primary: false },
];

const socialLinks = [
  { label: 'LinkedIn', href: 'https://linkedin.com/in/egel', icon: 'linkedin' },
  { label: 'GitHub', href: 'https://github.com/cvb0081', icon: 'github' },
  { label: 'Upwork', href: 'https://www.upwork.com/freelancers/~012899d2f987341308', icon: 'upwork' },
  { label: 'Email', href: 'mailto:xhaferajegel@gmail.com', icon: 'email' },
];
---

<section id="hero" class="relative min-h-screen flex items-start pt-28 sm:pt-32 lg:items-center overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute top-1/4 -right-32 w-[500px] h-[500px] bg-accent-blue/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 -left-32 w-[400px] h-[400px] bg-accent-teal/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6 w-full pb-12">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text Content -->
      <div class="order-2 lg:order-1 space-y-8">
        <div class="space-y-4">
          <p class="text-lg text-text-secondary font-medium animate-fade-in">Hello,</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.1] font-[family-name:var(--font-display)] animate-fade-in-up">
            I'm <span class="gradient-text">Egel Xhaferaj</span>
          </h1>
          <p class="text-xl sm:text-2xl lg:text-3xl font-semibold text-text-secondary leading-snug animate-fade-in-up delay-100">
            Turning complex problems into reliable software
          </p>
        </div>

        <p class="text-text-secondary text-base sm:text-lg leading-relaxed max-w-lg animate-fade-in-up delay-200">
          Whether you need an MVP built from scratch or a senior engineer to scale your system,
          I deliver clean, production-ready backend solutions.
        </p>

        <div class="flex flex-wrap items-center gap-4 animate-fade-in-up delay-300">
          <a href="#contact" class="btn-accent">
            Let's Work Together
          </a>

          <!-- Social links -->
          <div class="flex items-center gap-3">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target={link.icon !== 'email' ? '_blank' : undefined}
                rel={link.icon !== 'email' ? 'noopener noreferrer' : undefined}
                aria-label={link.label}
                class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-text-muted hover:text-text-primary hover:border-accent-blue/40 transition-all duration-200"
              >
                {link.icon === 'linkedin' && (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                )}
                {link.icon === 'github' && (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                )}
                {link.icon === 'upwork' && (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.548-1.405-.002-2.543-1.143-2.545-2.548V3.492H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3 0 5.439-2.452 5.439-5.45 0-3-2.439-5.439-5.439-5.439z"/></svg>
                )}
                {link.icon === 'email' && (
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                )}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Photo + Role Tags -->
      <div class="order-1 lg:order-2 flex flex-col items-center lg:items-end gap-4 lg:justify-end">
        <div class="relative">
          <!-- Glow behind photo -->
          <div class="absolute inset-0 bg-gradient-to-br from-accent-blue/20 to-accent-teal/20 rounded-2xl blur-2xl scale-90 opacity-60"></div>

          <!-- Photo -->
          <div class="relative w-64 h-64 sm:w-80 sm:h-80 lg:w-[320px] lg:h-[320px] rounded-2xl overflow-hidden border-2 border-border/60 bg-bg">
            <img
              src="/headshot.jpg"
              alt="Egel Xhaferaj, Software Engineer"
              class="w-full h-full object-cover"
              loading="eager"
              width="320"
              height="320"
            />
            <!-- Vignette to blend white edges into dark theme -->
            <div class="absolute inset-0 pointer-events-none shadow-[inset_0_0_60px_20px_rgba(10,10,15,0.7)]"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-bg/80 via-transparent to-bg/30 pointer-events-none"></div>
          </div>
        </div>

        <!-- Role hierarchy -->
        <div class="w-64 sm:w-80 lg:w-[320px] flex flex-col items-center gap-3 animate-fade-in" style="animation-delay: 300ms">
          <!-- Primary role -->
          <div class="flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-gradient-to-r from-accent-blue/15 to-accent-teal/15 border border-accent-blue/30">
            <span class="w-2 h-2 rounded-full bg-gradient-to-br from-accent-blue to-accent-teal shrink-0"></span>
            <span class="text-sm font-semibold text-text-primary">Software Engineer</span>
          </div>

          <!-- Connector line -->
          <div class="w-px h-3 bg-gradient-to-b from-accent-blue/30 to-border"></div>

          <!-- Derived roles -->
          <div class="flex flex-wrap justify-center gap-2">
            <span class="pill text-text-muted text-xs">Technical Lead</span>
            <span class="pill text-text-muted text-xs">Backend Architect</span>
            <span class="pill text-text-muted text-xs">Product Engineer</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.6s ease-out both;
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out both;
  }
  .delay-100 { animation-delay: 100ms; }
  .delay-200 { animation-delay: 200ms; }
  .delay-300 { animation-delay: 300ms; }
</style>
