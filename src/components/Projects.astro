---

<section id="projects" class="relative">
  <!-- Background accent -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent-blue/3 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-6 relative">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-black font-[family-name:var(--font-display)]">
        <span class="gradient-text">Projects</span>
      </h2>
      <p class="text-text-secondary mt-4 max-w-2xl mx-auto">
        Real systems I've built, led, and shipped. Business results paired with technical depth.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="hidden lg:block absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-accent-blue/30 via-accent-teal/20 to-transparent"></div>

      <div class="space-y-8">
        {projects.map((project, i) => (
          <article class="relative lg:pl-20">
            <!-- Timeline dot -->
            <div class="hidden lg:flex absolute left-6 top-8 w-5 h-5 rounded-full border-2 border-accent-blue/50 bg-bg items-center justify-center">
              <div class="w-2 h-2 rounded-full bg-accent-teal"></div>
            </div>

            <div class="card-glow rounded-2xl overflow-hidden">
              <div class="p-7 sm:p-8">
                <!-- Header -->
                <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
                  <div>
                    <h3 class="text-xl font-bold">
                      {project.name}
                      {project.subtitle && <span class="text-text-muted font-normal text-base ml-1">/ {project.subtitle}</span>}
                    </h3>
                    <span class="text-sm text-accent-teal font-medium">{project.role}</span>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-2xl font-black gradient-text font-[family-name:var(--font-display)] whitespace-nowrap">{project.metric.value}</div>
                    <div class="text-xs text-text-muted uppercase tracking-wider">{project.metric.label}</div>
                  </div>
                </div>

                <!-- Summary -->
                <p class="text-text-secondary text-sm leading-relaxed mb-5">
                  {project.summary}
                </p>

                <!-- Highlights -->
                <ul class="space-y-2 mb-6">
                  {project.highlights.map((h) => (
                    <li class="flex gap-2.5 text-sm text-text-secondary leading-relaxed">
                      <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent-teal shrink-0"></span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>

                <!-- Tech stack -->
                <div class="flex flex-wrap gap-2">
                  {project.tech.map((t) => (
                    <span class="text-xs px-2.5 py-1 rounded-full bg-accent-blue/5 border border-accent-blue/15 text-text-secondary">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
